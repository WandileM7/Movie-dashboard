# MongoDB connection (local dev or MongoDB Atlas free tier)
MONGO_URL=mongodb://localhost:27017
DB_NAME=taste_cartography

# Auth: long random string used to sign session JWTs.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# TMDB v4 Read Access Token (free, themoviedb.org -> Settings -> API).
# Enables real trailers + region streaming providers. Optional but recommended.
TMDB_API_KEY=

# OPTIONAL: exact "watch now" deep links per platform (instead of search links).
# Free tier at rapidapi.com -> Streaming Availability (Movie of the Night).
STREAMING_AVAILABILITY_API_KEY=
